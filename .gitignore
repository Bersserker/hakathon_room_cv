# === Данные (основное для ML) ===
/data/

# Более детальная настройка для data/ (раскомментируйте нужные строки)
# /data/raw/          # сырые данные (обычно не коммитятся)
# /data/processed/    # обработанные данные
# /data/interim/     # промежуточные результаты обработки
# /data/external/    # внешние данные

# Игнорируем конкретные форматы данных в data/
/data/*.csv
/data/*.json
/data/*.parquet
/data/*.h5
/data/*.hdf5
/data/*.pkl
/data/*.pickle
/data/*.npy
/data/*.npz
/data/*.zip
/data/*.tar
/data/*.gz

# Подпапки с данными любого уровня вложенности
/data/**/*.csv
/data/**/*.json
/data/**/*.parquet
/data/**/*.h5
/data/**/*.pkl
/data/**/*.npy

# === Модели (обычно не коммитятся) ===
/models/
models/  # добавлено: игнорируем папку models/ на любом уровне вложенности
**/models/  # игнорируем все папки models/ в любом месте проекта
*.pth
*.pt
*.h5
*.hdf5
*.ckpt
*.model
*.pickle
*.joblib

# === Логи и метрики ===
